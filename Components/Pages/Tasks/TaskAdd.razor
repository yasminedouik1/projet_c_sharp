@page "/tasks/{ProjectId:int}/add"
@rendermode InteractiveServer
@using ProjectManager.Models
@using ProjectManager.Services
@inject ITaskService TaskService
@inject IMemberService MemberService
@inject NavigationManager NavManager

<PageTitle>Nouvelle Tâche</PageTitle>
<h1>Nouvelle Tâche</h1>

<EditForm Model="_task" OnValidSubmit="Save">
    <DataAnnotationsValidator />

    <div class="card p-4" style="max-width:600px;">
        <div class="mb-3">
            <label class="form-label">Titre</label>
            <InputText class="form-control" @bind-Value="_task.Title" />
            <ValidationMessage For="() => _task.Title" />
        </div>

        <div class="mb-3">
            <label class="form-label">Description</label>
            <InputTextArea class="form-control" @bind-Value="_task.Description" />
        </div>

        <div class="mb-3">
            <label class="form-label">Date limite</label>
            <InputDate class="form-control" @bind-Value="_task.DueDate" />
            <ValidationMessage For="() => _task.DueDate" />
        </div>

        <div class="mb-3">
            <label class="form-label">Statut</label>
            <InputSelect class="form-select" @bind-Value="_task.Status">
                @foreach (var s in Enum.GetValues<Models.TaskStatus>())
                {
                    <option value="@s">@s</option>
                }
            </InputSelect>
        </div>

        <div class="mb-3">
            <label class="form-label">Assigner à</label>
            <InputSelect class="form-select" @bind-Value="_task.AssignedMemberId">
                <option value="">-- Non assigné --</option>
                @foreach (var m in _members)
                {
                    <option value="@m.Id">@m.FullName</option>
                }
            </InputSelect>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Enregistrer</button>
            <button type="button" class="btn btn-secondary"
                    @onclick="Cancel">Annuler</button>
        </div>
    </div>
</EditForm>

@code {
    [Parameter] public int ProjectId { get; set; }

    private ProjectTask _task = new() { DueDate = DateTime.Now.AddDays(7) };
    private List<Member> _members = new();

    protected override async Task OnInitializedAsync()
    {
        _members      = await MemberService.GetAllAsync();
        _task.ProjectId = ProjectId;
    }

    private async Task Save()
    {
        await TaskService.AddAsync(_task);
        NavManager.NavigateTo("/tasks/" + ProjectId);
    }

    private void Cancel() => NavManager.NavigateTo("/tasks/" + ProjectId);
}