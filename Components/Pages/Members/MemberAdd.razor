@page "/members/add"
@rendermode InteractiveServer
@using ProjectManager.Models
@using ProjectManager.Services
@inject IMemberService MemberService
@inject NavigationManager NavManager

<PageTitle>Nouveau Membre</PageTitle>
<h1>Nouveau Membre</h1>

<EditForm Model="_member" OnValidSubmit="Save">
    <DataAnnotationsValidator />

    <div class="card p-4" style="max-width:500px;">
        <div class="mb-3">
            <label class="form-label">Nom complet</label>
            <InputText class="form-control" @bind-Value="_member.FullName" />
            <ValidationMessage For="() => _member.FullName" />
        </div>

        <div class="mb-3">
            <label class="form-label">Email</label>
            <InputText class="form-control" @bind-Value="_member.Email" />
            <ValidationMessage For="() => _member.Email" />
        </div>

        <div class="mb-3">
            <label class="form-label">Rôle</label>
            <InputText class="form-control" @bind-Value="_member.Role"  />
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Enregistrer</button>
            <button type="button" class="btn btn-secondary"
                    @onclick="Cancel">Annuler</button>
        </div>
    </div>
</EditForm>

@code {
    private Member _member = new();

    private async Task Save()
    {
        await MemberService.AddAsync(_member);
        NavManager.NavigateTo("/members");
    }

    private void Cancel() => NavManager.NavigateTo("/members");
}